# Copy to ibbq.env and fill in. Keep this file private (chmod 600).

# From @BotFather when you create the bot:
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWxyz

# Your numeric chat id (see README for how to find it):
TELEGRAM_CHAT_ID=987654321

# BLE advertised name. Inkbird IBT-4XS advertises as "iBBQ".
IBBQ_NAME=iBBQ

# Optional: pin to a specific device by MAC (overrides name matching).
# Useful if there are multiple iBBQ units around.
# IBBQ_MAC=AA:BB:CC:DD:EE:FF

# Where to persist per-probe alert settings:
IBBQ_STATE=/home/youruser/ibbq/probe_state.json
